PORT=5000
MONGODB_URI=mongodb+srv://USER:PASSWORD@HOST/DATABASE
BASE_URL=https://your-backend.up.railway.app
ALLOWED_ORIGINS=https://hand-aura-front-production.up.railway.app,http://localhost:5500,http://127.0.0.1:5500
JWT_SECRET=your_jwt_secret_here

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
MAIL_FROM=your_email@gmail.com

GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

ADMIN_EMAIL=admin@example.com

# Security
DATA_ENCRYPTION_KEY=your_data_encryption_key
ADMIN_2FA_REQUIRED=false
AUTO_BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=7

