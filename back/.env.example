PORT=5000
MONGODB_URI=mongodb+srv://USER:PASSWORD@HOST/DATABASE
BASE_URL=https://your-backend.up.railway.app
ALLOWED_ORIGINS=https://hand-aura-front-production.up.railway.app,http://localhost:5500,http://127.0.0.1:5500
JWT_SECRET=your_jwt_secret_here

# Email (SendGrid only)
SENDGRID_API_KEY=
MAIL_FROM=your_verified_sender@example.com

GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

ADMIN_EMAIL=admin@example.com

# Security
DATA_ENCRYPTION_KEY=your_data_encryption_key
ADMIN_2FA_REQUIRED=false
AUTO_BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=7
UPLOAD_DIR=/data/uploads
MARKETING_JOBS_ENABLED=true
MARKETING_JOB_INTERVAL_MINUTES=15
ABANDONED_CART_DELAY_MINUTES=60
ABANDONED_REMINDER_COOLDOWN_HOURS=24
PROMO_INTERVAL_HOURS=72

# Payments
FRONTEND_URL=https://hand-aura-front-production.up.railway.app
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
PAYPAL_CLIENT_ID=
PAYPAL_WEBHOOK_ID=
PAYMOB_API_KEY=
PAYMOB_HMAC_SECRET=
PAYMOB_INTEGRATION_ID=
PAYMOB_IFRAME_ID=
FAWRY_MERCHANT_CODE=
FAWRY_SECRET=
